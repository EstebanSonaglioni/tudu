{"swagger": "2.0", "info": {"title": "Invera To-Do API", "description": "API de gestión de To-Dos", "version": "v1"}, "host": "127.0.0.1:8000", "schemes": ["http"], "basePath": "/api", "consumes": ["application/json"], "produces": ["application/json"], "securityDefinitions": {"Bearer": {"type": "apiKey", "name": "Authorization", "in": "header"}}, "security": [{"Bearer": []}], "paths": {"/auth/login/": {"post": {"operationId": "auth_login_create", "description": "Takes a set of user credentials and returns an access and refresh JSON web\ntoken pair to prove the authentication of those credentials.", "parameters": [{"name": "data", "in": "body", "required": true, "schema": {"$ref": "#/definitions/TokenObtainPair"}}], "responses": {"201": {"description": "", "schema": {"$ref": "#/definitions/TokenObtainPair"}}}, "tags": ["auth"]}, "parameters": []}, "/todos/complete/{todo_id}/": {"patch": {"operationId": "todos_complete_partial_update", "description": "", "parameters": [], "responses": {"200": {"description": ""}}, "tags": ["todos"]}, "parameters": [{"name": "todo_id", "in": "path", "required": true, "type": "string"}]}, "/todos/create/": {"post": {"operationId": "todos_create_create", "description": "", "parameters": [{"name": "data", "in": "body", "required": true, "schema": {"$ref": "#/definitions/Todo"}}], "responses": {"201": {"description": "", "schema": {"$ref": "#/definitions/Todo"}}}, "tags": ["todos"]}, "parameters": []}, "/todos/delete/{todo_id}/": {"delete": {"operationId": "todos_delete_delete", "description": "Elimina el todo indicado por ID", "parameters": [], "responses": {"200": {"description": "Todo deleted"}, "404": {"description": "Todo not found"}}, "tags": ["todos"]}, "parameters": [{"name": "todo_id", "in": "path", "required": true, "type": "string"}]}, "/todos/get/": {"get": {"operationId": "todos_get_list", "description": "Lista los todos del usuario autenticado", "parameters": [{"name": "search", "in": "query", "description": "Filtrar por texto en el título", "type": "string"}, {"name": "date", "in": "query", "description": "Filtrar por fecha de creación (YYYY-MM-DD)", "type": "string"}], "responses": {"200": {"description": "", "schema": {"type": "array", "items": {"$ref": "#/definitions/Todo"}}}, "404": {"description": "Todo not found"}, "400": {"description": "Invalid request"}}, "tags": ["todos"]}, "parameters": []}, "/users/login/": {"post": {"operationId": "users_login_create", "description": "Ingresar con usuario y contraseña", "parameters": [{"name": "data", "in": "body", "required": true, "schema": {"$ref": "#/definitions/User"}}], "responses": {"200": {"description": "", "schema": {"type": "object", "properties": {"refresh": {"description": "Token para hacer refresh", "type": "string"}, "access": {"description": "Token de autenticación", "type": "string"}}}}, "401": {"description": "Invalid credentials"}}, "tags": ["users"]}, "parameters": []}, "/users/register/": {"post": {"operationId": "users_register_create", "description": "Registrar un usuario nuevo", "parameters": [{"name": "data", "in": "body", "required": true, "schema": {"$ref": "#/definitions/UserCreate"}}], "responses": {"200": {"description": "", "schema": {"type": "object", "properties": {"id": {"description": "ID del usuario creado", "type": "integer"}, "username": {"description": "Username", "type": "string"}}}}}, "tags": ["users"]}, "parameters": []}}, "definitions": {"TokenObtainPair": {"required": ["username", "password"], "type": "object", "properties": {"username": {"title": "Username", "type": "string", "minLength": 1}, "password": {"title": "Password", "type": "string", "minLength": 1}}}, "Todo": {"required": ["title"], "type": "object", "properties": {"id": {"title": "ID", "type": "integer", "readOnly": true}, "title": {"title": "Title", "type": "string", "maxLength": 255, "minLength": 1}, "completed": {"title": "Completed", "type": "boolean"}, "created_at": {"title": "Created at", "type": "string", "format": "date-time", "readOnly": true}}}, "User": {"required": ["username", "password"], "type": "object", "properties": {"id": {"title": "ID", "type": "integer", "readOnly": true}, "username": {"title": "Username", "description": "Required. 150 characters or fewer. Letters, digits and @/./+/-/_ only.", "type": "string", "pattern": "^[\\w.@+-]+$", "maxLength": 150, "minLength": 1}, "password": {"title": "Password", "type": "string", "maxLength": 128, "minLength": 1}}}, "UserCreate": {"required": ["username", "password"], "type": "object", "properties": {"username": {"title": "Username", "description": "Required. 150 characters or fewer. Letters, digits and @/./+/-/_ only.", "type": "string", "pattern": "^[\\w.@+-]+$", "maxLength": 150, "minLength": 1}, "password": {"title": "Password", "type": "string", "maxLength": 128, "minLength": 1}}}}}